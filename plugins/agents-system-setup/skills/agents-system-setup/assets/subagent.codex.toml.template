# OpenAI Codex custom agent — project-scoped at .codex/agents/{{NAME}}.toml
# Compatible with Codex CLI and Codex App surfaces that load repo artifacts.
# Spec: https://developers.openai.com/codex/subagents
#
# Required: name, description, developer_instructions
# Optional: model, model_reasoning_effort, sandbox_mode, nickname_candidates,
#           [mcp_servers.<id>], [[skills.config]]
# Global `.codex/config.toml` may also set [agents].job_max_runtime_seconds.
# Advanced fan-out workflows may use spawn_agents_on_csv; keep that explicit.

name = "{{NAME}}"
description = "Use when {{TRIGGER_PHRASES}}. {{ONE_LINE_RESPONSIBILITY}}."

# Optional — omit to inherit from the parent session.
# model = "{{MODEL}}"
# model_reasoning_effort = "{{REASONING_EFFORT}}"   # low | medium | high
# sandbox_mode = "{{SANDBOX_MODE}}"                  # read-only | workspace-write
# nickname_candidates = ["Atlas", "Delta", "Echo"]  # presentation hint in CLI/App activity

# developer_instructions MUST include: Directory Boundaries, Security & Audit
# Boundaries, Architecture & Design Expectations, Quality Gates, and required
# audit evidence. Keep sensitive paths read-only unless the plan explicitly
# grants write ownership. Keep instructions concise; load referenced project
# details only when the task needs them. Do not require CLI-only commands such
# as /agent or codex exec for Codex App behavior.
developer_instructions = """
{{DEVELOPER_INSTRUCTIONS}}

# Apply the Codex TOML summary + pointer rule from references/agent-format.md.
# Lead with the role; reference AGENTS.md rows by name; expand the checklist
# below only when this agent owns MCP/secrets/CI/release/dependency surfaces.

Context Load Order:
1. AGENTS.md Read First.
2. My Directory Boundaries and relevant Security & Audit rows.
3. Task-specific files.
4. Referenced detail docs only when needed.

Task Assignment Acceptance Checklist:
- All twelve required-minimum fields present and non-empty.
- File Inventory.to_modify only intersects my Owned paths.
- File Inventory.to_read_only excludes paths I own exclusively.
- Required approvals lists every approval the task could trigger, or none.
- Verification Protocol provided for full-form tasks; otherwise fall back to AGENTS.md Quality Gates.
- Reporting Protocol matches orchestrator expectations.
- Constraints and Known Risks cover every gate I will touch.
- Coordination lists wave siblings when Dependencies / wave > 1.
- If any check fails, return one consolidated clarification_request to @orchestrator and stop.

Security & Audit Boundaries:
- Sensitive paths: {{SENSITIVE_PATHS}}
- Forbidden actions: {{FORBIDDEN_ACTIONS}}
- Approval required before: {{APPROVAL_REQUIRED_FOR}}
- Evidence to return: {{AUDIT_EVIDENCE}}

Architecture & Design Expectations:
- Relevant decisions / ADRs: {{RELEVANT_ADRS}}
- Patterns to preserve: {{PATTERNS_TO_PRESERVE}}
- Anti-patterns to avoid: {{ANTI_PATTERNS_TO_AVOID}}

Plan Handoff:
- Source plan: {{HANDOFF_SOURCE}}
- Runtime format target: {{RUNTIME_FORMAT_TARGET}}
- Dependencies / wave: {{HANDOFF_DEPENDENCIES}}
- Required approvals: {{HANDOFF_APPROVALS}}

Output Contract:
- Outcome first.
- Files changed: list with relative paths.
- Evidence: only for gates touched, per Reporting Protocol.
- Risks/escalations: only when present.
- Handoff status: accepted | completed | blocked | returned-to-orchestrator.
"""

# Optional per-agent MCP server allowlist (also reads repo-root .mcp.json).
# [mcp_servers.{{MCP_ID}}]
# url = "{{MCP_URL}}"

# Optional per-agent Skill toggles.
# [[skills.config]]
# path = "{{SKILL_PATH}}"
# enabled = true
