{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ytthuan/agents-system-setup/schemas/codex-marketplace.schema.json",
  "title": "OpenAI Codex CLI marketplace descriptor (.agents/plugins/marketplace.json)",
  "type": "object",
  "additionalProperties": true,
  "required": ["name", "plugins"],
  "properties": {
    "name": { "type": "string" },
    "interface": {
      "type": "object",
      "properties": {
        "displayName": { "type": "string" }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "source"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "source": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["source"],
                "properties": {
                  "source": { "enum": ["local", "git", "git-subdir", "url"] },
                  "path": { "type": "string" },
                  "url": { "type": "string" },
                  "ref": { "type": "string" },
                  "subdir": { "type": "string" }
                },
                "additionalProperties": true
              }
            ]
          },
          "policy": {
            "type": "object",
            "properties": {
              "installation": { "type": "string" },
              "authentication": { "type": "string" }
            }
          },
          "category": { "type": "string" }
        }
      }
    }
  }
}
